    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.1",
    "@text-them/shared": "*",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "mongodb": "^6.10.0",
    "pino": "^9.5.0",
    "twilio": "^5.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "mongodb-memory-server": "^10.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
