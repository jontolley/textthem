# ─── Backend (apps/api) ───────────────────────────────────────────────
# MongoDB connection string (local docker default shown; use Atlas SRV URI in prod)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=text_them

# Server
PORT=8080
NODE_ENV=development
# Comma-separated list of allowed CORS origins (the web app URL)
CORS_ORIGINS=http://localhost:5173

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Outbound sender — set ONE of the following (at least one is required):
#  - For low volume / getting started: a plain Twilio number in E.164 format.
TWILIO_FROM_NUMBER=+15551234567
#  - Recommended once you scale / register A2P 10DLC: a Messaging Service SID.
#    If set, it takes precedence over TWILIO_FROM_NUMBER.
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public base URL the Twilio webhook is reachable at (for signature validation)
PUBLIC_BASE_URL=http://localhost:8080
# Set to "true" to skip Twilio signature validation in local dev (never in prod)
TWILIO_SKIP_SIGNATURE_VALIDATION=false
# Org info returned on HELP messages
ORG_NAME=My Organization

# Clerk (backend verifies JWTs)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key-here

# ─── Frontend (apps/web) ──────────────────────────────────────────────
# These are read at build time by Vite (must be prefixed with VITE_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key-here
VITE_API_BASE_URL=http://localhost:8080
